    "reflect-metadata": "0.2.1"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "@types/node": "20.12.7",
    "@types/react": "18.2.74",
    "@types/react-dom": "18.2.24",
    "@types/sqlite3": "3.1.11",
    "ts-node": "10.9.2",
    "tailwindcss": "3.4.1",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.38",
    "@tailwindcss/forms": "0.5.7"
  }
